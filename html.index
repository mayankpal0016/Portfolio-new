<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Mayank Pal — Performance Marketer</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700;800&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#f8faff;
  --ink:#0e1330;
  --ink2:#3a4060;
  --white:#ffffff;
  --card-border:rgba(79,70,229,.14);
  --shadow:rgba(30,41,99,.1);
  --grad:linear-gradient(90deg,#0ea5e9,#2563eb,#7c3aed,#c026d3);
  --grad-diag:linear-gradient(135deg,#0ea5e9,#2563eb,#7c3aed,#c026d3);
  --radius:22px;
  --font:'Sora',system-ui,sans-serif;
}
html{scroll-behavior:smooth}
body{
  font-family:var(--font);
  background:var(--bg);
  color:var(--ink);
  font-weight:300;
  overflow-x:hidden;
  cursor:none;
}
body::before{
  content:'';
  position:fixed;
  inset:0;
  background:
    radial-gradient(ellipse 60% 60% at 0% 0%,rgba(14,165,233,.08) 0%,transparent 70%),
    radial-gradient(ellipse 50% 50% at 100% 100%,rgba(124,58,237,.07) 0%,transparent 70%);
  pointer-events:none;
  z-index:0;
}

/* ── SCROLL PROGRESS ── */
#scroll-bar{
  position:fixed;top:0;left:0;height:3px;width:0%;
  background:var(--grad);z-index:9999;transition:width .05s;
}

/* ── CURSOR ── */
#cur-dot{
  position:fixed;width:8px;height:8px;border-radius:50%;
  background:var(--grad-diag);
  transform:translate(-50%,-50%);
  pointer-events:none;z-index:9998;transition:transform .1s;
}
#cur-ring{
  position:fixed;width:36px;height:36px;border-radius:50%;
  border:1.5px solid rgba(37,99,235,.5);
  transform:translate(-50%,-50%);
  pointer-events:none;z-index:9997;
  transition:width .3s,height .3s,border-color .3s;
}
#cur-ring.expand{width:56px;height:56px;border-color:#7c3aed;}

/* ── CANVAS ── */
#bg-canvas{position:fixed;inset:0;z-index:1;pointer-events:none;}

/* ── PRELOADER ── */
#preloader{
  position:fixed;inset:0;z-index:10000;
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  background:var(--ink);
  gap:28px;
}
.pre-pct{
  font-size:clamp(64px,10vw,120px);
  font-weight:800;
  background:var(--grad);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  letter-spacing:-0.04em;
}
.pre-bar-wrap{width:min(320px,80vw);height:2px;background:rgba(255,255,255,.12);border-radius:2px;overflow:hidden;}
.pre-bar{height:100%;width:0%;background:var(--grad);transition:width .05s linear;}
.pre-label{color:rgba(255,255,255,.4);font-size:11px;letter-spacing:.3em;text-transform:uppercase;}

.curtain{
  position:fixed;left:0;right:0;height:50%;z-index:9999;background:var(--ink);
  transition:transform .8s cubic-bezier(.76,0,.24,1);
}
#curtain-top{top:0;}
#curtain-bot{bottom:0;}
#curtain-top.open{transform:translateY(-100%);}
#curtain-bot.open{transform:translateY(100%);}

/* ── NAVBAR ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:500;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 48px;height:64px;
  opacity:0;transform:translateY(-100%);
  transition:opacity .6s,transform .6s,background .4s,backdrop-filter .4s,box-shadow .4s;
}
nav.visible{opacity:1;transform:none;}
nav.scrolled{
  background:rgba(248,250,255,.82);
  backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);
  box-shadow:0 2px 24px rgba(30,41,99,.08);
}
.nav-logo{
  font-size:18px;font-weight:800;letter-spacing:-0.04em;
  background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.nav-links{display:flex;gap:32px;}
.nav-links a{
  font-size:13px;font-weight:600;letter-spacing:.04em;
  color:var(--ink2);text-decoration:none;
  transition:color .2s;
}
.nav-links a:hover{color:#2563eb;}

/* ── LAYOUT ── */
main{position:relative;z-index:10;}
section{position:relative;padding:120px 48px;}
.container{max-width:1200px;margin:0 auto;}

/* ── HERO ── */
#hero{
  min-height:100vh;display:flex;align-items:center;
  padding-top:80px;overflow:hidden;
}
.hero-inner{
  display:grid;grid-template-columns:1fr 420px;gap:80px;align-items:center;
  max-width:1200px;margin:0 auto;width:100%;
}
.hero-eyebrow{
  font-size:11px;font-weight:600;letter-spacing:.3em;text-transform:uppercase;
  color:var(--ink2);margin-bottom:24px;
  display:flex;align-items:center;gap:12px;
}
.hero-eyebrow::before{
  content:'';display:block;width:32px;height:2px;
  background:var(--grad);border-radius:2px;
}
.hero-name{
  font-size:clamp(52px,6vw,88px);font-weight:800;letter-spacing:-0.04em;
  line-height:1;margin-bottom:8px;
}
.hero-name-first{color:var(--ink);}
.hero-name-last{
  background:var(--grad);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  display:block;
}
.hero-value{
  font-size:clamp(16px,1.5vw,19px);color:var(--ink2);
  line-height:1.65;margin:32px 0 40px;max-width:540px;
}
.hero-value strong{
  background:var(--grad);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  font-weight:700;
}
.hero-ctas{display:flex;gap:16px;flex-wrap:wrap;margin-bottom:56px;}
.btn{
  display:inline-flex;align-items:center;justify-content:center;
  padding:14px 32px;border-radius:100px;
  font-size:14px;font-weight:700;font-family:var(--font);
  cursor:none;text-decoration:none;
  transition:transform .2s,box-shadow .2s;
  position:relative;overflow:hidden;
}
.btn-primary{
  background:var(--grad);color:#fff;
  box-shadow:0 8px 32px rgba(37,99,235,.35);
}
.btn-primary::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(120deg,transparent 30%,rgba(255,255,255,.25) 50%,transparent 70%);
  transform:translateX(-100%);
  transition:transform .5s ease;
}
.btn-primary:hover::after{transform:translateX(100%);}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 12px 40px rgba(37,99,235,.5);}
.btn-secondary{
  background:transparent;color:var(--ink);
  border:1.5px solid var(--card-border);
  backdrop-filter:blur(8px);
}
.btn-secondary:hover{border-color:#2563eb;color:#2563eb;transform:translateY(-2px);}

.hero-stats{display:flex;gap:32px;flex-wrap:wrap;}
.stat-item{
  padding-left:16px;
  border-left:3px solid transparent;
  border-image:var(--grad) 1;
}
.stat-val{
  font-size:28px;font-weight:800;letter-spacing:-0.04em;
  background:var(--grad);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  display:block;
}
.stat-lbl{font-size:11px;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:var(--ink2);}

/* WATERMARK */
.hero-watermark{
  position:absolute;top:50%;left:50%;
  transform:translateX(-50%) translateY(-50%);
  font-size:clamp(100px,18vw,240px);font-weight:800;letter-spacing:-0.04em;
  color:transparent;
  -webkit-text-stroke:1px rgba(37,99,235,.07);
  white-space:nowrap;z-index:0;pointer-events:none;
  will-change:transform;
}

/* PHOTO */
.photo-wrap{
  position:relative;display:flex;align-items:center;justify-content:center;
  width:360px;height:360px;flex-shrink:0;
}
.photo-glow{
  position:absolute;inset:-16px;border-radius:50%;
  background:conic-gradient(from 0deg,#0ea5e9,#2563eb,#7c3aed,#c026d3,#0ea5e9);
  animation:spin 4s linear infinite;
  filter:blur(16px);opacity:.6;
}
.photo-ring{
  position:absolute;inset:-6px;border-radius:50%;
  border:2px dashed rgba(124,58,237,.35);
  animation:spin 8s linear infinite reverse;
}
.photo-frame{
  width:310px;height:310px;border-radius:50%;
  border:8px solid #fff;
  overflow:hidden;position:relative;z-index:2;
  box-shadow:0 24px 64px rgba(30,41,99,.2);
  transition:transform .3s ease;
}
.photo-frame img{width:100%;height:100%;object-fit:cover;}
.photo-placeholder{
  width:100%;height:100%;
  background:linear-gradient(135deg,#e0e7ff,#c7d2fe);
  display:flex;align-items:center;justify-content:center;
  font-size:72px;font-weight:800;color:#4f46e5;letter-spacing:-0.04em;
}

.orbit-dot{
  position:absolute;width:12px;height:12px;border-radius:50%;
  background:var(--grad-diag);
  box-shadow:0 0 12px rgba(124,58,237,.6);
  z-index:3;
}

.chip{
  position:absolute;z-index:4;
  background:#fff;border:1px solid var(--card-border);
  border-radius:100px;padding:8px 14px;
  display:flex;align-items:center;gap:8px;
  box-shadow:0 8px 24px var(--shadow);
  font-size:12px;font-weight:700;white-space:nowrap;
  animation:float 3s ease-in-out infinite;
}
.chip-icon{font-size:16px;}
.chip-val{
  background:var(--grad);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.chip-1{top:10px;right:-40px;animation-delay:0s;}
.chip-2{bottom:40px;right:-50px;animation-delay:.8s;}
.chip-3{bottom:0px;left:-20px;animation-delay:1.6s;}

@keyframes spin{to{transform:rotate(360deg);}}
@keyframes float{0%,100%{transform:translateY(0);}50%{transform:translateY(-8px);}}

/* ── SECTION HEADER ── */
.sec-head{margin-bottom:64px;}
.sec-eyebrow{
  font-size:11px;font-weight:600;letter-spacing:.3em;
  text-transform:uppercase;color:var(--ink2);margin-bottom:16px;
  display:flex;align-items:center;gap:12px;
}
.sec-num{
  font-size:80px;font-weight:800;letter-spacing:-0.04em;
  color:transparent;-webkit-text-stroke:1.5px rgba(37,99,235,.18);
  line-height:1;margin-right:12px;
}
.sec-title{
  font-size:clamp(36px,4vw,56px);font-weight:800;
  letter-spacing:-0.04em;line-height:1.05;
  display:flex;align-items:center;flex-wrap:wrap;gap:0 12px;
}
.sec-grad{
  background:var(--grad);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  font-style:italic;
}

/* ── MARQUEE ── */
.marquee-wrap{
  position:relative;padding:28px 0;
  transform:rotate(-1.2deg);
  overflow:hidden;margin:0 -80px;
}
.marquee-wrap.alt{transform:rotate(1.2deg);margin-top:-8px;}
.marquee-inner{
  display:flex;align-items:center;
  width:max-content;animation:scroll-left 28s linear infinite;
  background:var(--grad);
  padding:14px 0;
}
.marquee-wrap.alt .marquee-inner{
  background:transparent;border-top:1.5px solid rgba(37,99,235,.2);border-bottom:1.5px solid rgba(37,99,235,.2);
  animation-direction:reverse;
}
.marquee-inner:hover{animation-play-state:paused;}
.mq-item{
  font-size:13px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;
  padding:0 24px;color:#fff;display:flex;align-items:center;gap:20px;white-space:nowrap;
}
.mq-item::after{content:'◆';font-size:8px;opacity:.7;}
.marquee-wrap.alt .mq-item{
  color:var(--ink2);
}
.marquee-wrap.alt .mq-item.outlined{
  -webkit-text-stroke:1px rgba(37,99,235,.4);
  color:transparent;
}
@keyframes scroll-left{0%{transform:translateX(0);}100%{transform:translateX(-50%);}}

/* ── ABOUT ── */
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start;}
.quote-card{
  background:#fff;border:1px solid var(--card-border);border-radius:var(--radius);
  padding:48px;position:relative;overflow:hidden;
  box-shadow:0 8px 40px var(--shadow);
  grid-column:1/-1;
}
.quote-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:5px;
  background:var(--grad);
}
.quote-text{
  font-size:clamp(17px,1.8vw,22px);line-height:1.7;color:var(--ink2);font-weight:300;
  font-style:italic;padding-left:28px;border-left:3px solid transparent;
  border-image:var(--grad) 1;
}
.stat-band{
  display:grid;grid-template-columns:repeat(4,1fr);gap:24px;margin-top:40px;
  grid-column:1/-1;
}
.stat-band-item{
  background:#fff;border:1px solid var(--card-border);border-radius:var(--radius);
  padding:32px 28px;text-align:center;
  box-shadow:0 4px 24px var(--shadow);
  position:relative;overflow:hidden;
}
.stat-band-item::before{content:'';position:absolute;top:0;left:0;right:0;height:5px;background:var(--grad);}
.stat-band-num{
  font-size:36px;font-weight:800;letter-spacing:-0.04em;
  background:var(--grad);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  display:block;
}
.stat-band-lbl{font-size:11px;font-weight:600;letter-spacing:.25em;text-transform:uppercase;color:var(--ink2);margin-top:6px;}

/* ── EXPERIENCE ── */
.exp-stack{display:flex;flex-direction:column;gap:0;}
.exp-card{
  background:#fff;border:1px solid var(--card-border);border-radius:var(--radius);
  padding:48px 48px 48px 56px;
  position:relative;overflow:hidden;
  box-shadow:0 8px 40px var(--shadow);
  margin-bottom:0;
  transition:transform .4s,opacity .4s,box-shadow .4s;
}
.exp-card::before{content:'';position:absolute;top:0;left:0;right:0;height:5px;background:var(--grad);}
.exp-big-num{
  position:absolute;right:48px;top:32px;
  font-size:120px;font-weight:800;letter-spacing:-0.04em;
  color:transparent;-webkit-text-stroke:1px rgba(37,99,235,.08);
  line-height:1;pointer-events:none;
}
.exp-date{
  font-size:11px;font-weight:600;letter-spacing:.25em;text-transform:uppercase;
  color:var(--ink2);margin-bottom:16px;
  display:flex;align-items:center;gap:8px;
}
.exp-date::before{content:'';display:inline-block;width:20px;height:2px;background:var(--grad);border-radius:2px;}
.exp-role{font-size:clamp(22px,2.5vw,30px);font-weight:800;letter-spacing:-0.04em;color:var(--ink);margin-bottom:8px;}
.exp-company{
  font-size:18px;font-weight:700;margin-bottom:28px;
  background:var(--grad);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.exp-bullets{list-style:none;display:flex;flex-direction:column;gap:12px;margin-bottom:28px;}
.exp-bullets li{
  font-size:15px;color:var(--ink2);line-height:1.6;
  padding-left:20px;position:relative;
}
.exp-bullets li::before{
  content:'';position:absolute;left:0;top:.65em;
  width:8px;height:2px;
  background:var(--grad);border-radius:2px;
}
.exp-bullets li strong{
  color:var(--ink);font-weight:700;
  background:var(--grad);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.exp-tags{display:flex;flex-wrap:wrap;gap:8px;}
.exp-tag{
  font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;
  padding:6px 14px;border-radius:100px;
  border:1.5px solid var(--card-border);
  color:var(--ink2);
  transition:all .2s;
}
.exp-tag:hover{
  background:var(--grad);color:#fff;border-color:transparent;
  -webkit-text-fill-color:#fff;
}

/* ── SKILLS ── */
.skills-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:28px;margin-bottom:64px;}
.skill-card{
  background:#fff;border:1px solid var(--card-border);border-radius:var(--radius);
  padding:40px;position:relative;overflow:hidden;
  box-shadow:0 8px 40px var(--shadow);
  transition:transform .3s;
  cursor:none;
}
.skill-card::before{content:'';position:absolute;top:0;left:0;right:0;height:5px;background:var(--grad);}
.skill-card-glow{
  position:absolute;inset:0;border-radius:var(--radius);
  background:radial-gradient(circle at var(--mx,50%) var(--my,50%),rgba(37,99,235,.08) 0%,transparent 60%);
  pointer-events:none;opacity:0;transition:opacity .3s;
}
.skill-card:hover .skill-card-glow{opacity:1;}
.skill-num{
  font-size:48px;font-weight:800;letter-spacing:-0.04em;
  color:transparent;-webkit-text-stroke:1.5px rgba(37,99,235,.15);
  line-height:1;margin-bottom:4px;
}
.skill-title{font-size:20px;font-weight:800;letter-spacing:-0.02em;margin-bottom:20px;color:var(--ink);}
.skill-tags{display:flex;flex-wrap:wrap;gap:8px;}
.skill-tag{
  font-size:12px;font-weight:600;padding:6px 14px;border-radius:100px;
  border:1.5px solid var(--card-border);color:var(--ink2);
  transition:all .25s;cursor:none;
}
.skill-tag:hover{
  background:var(--grad);border-color:transparent;
  color:#fff;-webkit-text-fill-color:#fff;
}

/* tools marquee */
.tools-marquee{overflow:hidden;position:relative;}
.tools-inner{
  display:flex;gap:12px;width:max-content;
  animation:scroll-left 30s linear infinite;
}
.tools-inner:hover{animation-play-state:paused;}
.tool-pill{
  display:inline-flex;align-items:center;gap:8px;
  padding:10px 20px;border-radius:100px;
  background:#fff;border:1px solid var(--card-border);
  font-size:13px;font-weight:600;color:var(--ink2);
  white-space:nowrap;box-shadow:0 2px 12px var(--shadow);
  transition:all .2s;
}
.tool-pill:hover{background:var(--grad);color:#fff;border-color:transparent;-webkit-text-fill-color:#fff;}

/* ── HONORS ── */
.honors-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;}
.honor-card{
  background:#fff;border:1px solid var(--card-border);border-radius:var(--radius);
  padding:36px;position:relative;overflow:hidden;
  box-shadow:0 8px 32px var(--shadow);
  transition:transform .3s;
}
.honor-card::before{content:'';position:absolute;top:0;left:0;right:0;height:5px;background:var(--grad);}
.honor-card:hover{transform:translateY(-4px);}
.honor-icon{
  font-size:28px;margin-bottom:16px;display:block;
  background:var(--grad);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  font-weight:800;
}
.honor-name{font-size:17px;font-weight:700;color:var(--ink);margin-bottom:8px;line-height:1.4;}
.honor-issuer{font-size:12px;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:var(--ink2);}

/* ── EDUCATION ── */
.edu-list{display:flex;flex-direction:column;gap:0;}
.edu-row{
  display:grid;grid-template-columns:120px 1fr auto;gap:32px;align-items:center;
  padding:32px 0;border-bottom:1px solid rgba(79,70,229,.1);
  transition:padding-left .3s;
  position:relative;
}
.edu-row::after{
  content:'';position:absolute;left:0;top:0;bottom:0;width:3px;
  background:var(--grad);transform:scaleY(0);transition:transform .3s;
}
.edu-row:hover{padding-left:16px;}
.edu-row:hover::after{transform:scaleY(1);}
.edu-year{font-size:13px;font-weight:600;letter-spacing:.15em;color:var(--ink2);}
.edu-deg{font-size:18px;font-weight:700;color:var(--ink);margin-bottom:4px;}
.edu-inst{font-size:13px;color:var(--ink2);}
.edu-score{
  font-size:28px;font-weight:800;letter-spacing:-0.04em;
  background:var(--grad);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  white-space:nowrap;
}

/* ── CONTACT ── */
#contact{text-align:center;}
.contact-big{
  font-size:clamp(52px,9vw,120px);font-weight:800;letter-spacing:-0.04em;
  color:transparent;-webkit-text-stroke:2px var(--ink);
  line-height:1;margin-bottom:48px;
  display:inline-block;
  background-clip:text;-webkit-background-clip:text;
  transition:all .4s;
  cursor:none;
  position:relative;
  background-image:var(--grad);
  background-size:200%;
  background-position:right;
}
.contact-big:hover{
  -webkit-text-stroke:0px transparent;
  -webkit-text-fill-color:transparent;
  color:transparent;
  background-position:left;
}
.contact-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-bottom:48px;}
.contact-card{
  background:#fff;border:1px solid var(--card-border);border-radius:var(--radius);
  padding:36px;text-align:center;
  box-shadow:0 8px 32px var(--shadow);
  transition:transform .3s;
  position:relative;overflow:hidden;
  text-decoration:none;color:inherit;display:block;
}
.contact-card::before{content:'';position:absolute;top:0;left:0;right:0;height:5px;background:var(--grad);}
.contact-card:hover{transform:translateY(-4px);}
.contact-icon{font-size:28px;margin-bottom:12px;display:block;}
.contact-type{font-size:11px;font-weight:600;letter-spacing:.25em;text-transform:uppercase;color:var(--ink2);margin-bottom:8px;}
.contact-val{font-size:15px;font-weight:700;color:var(--ink);}
.open-badge{
  display:inline-flex;align-items:center;gap:10px;
  padding:12px 28px;border-radius:100px;
  background:#fff;border:1px solid rgba(22,163,74,.25);
  color:#166534;font-size:14px;font-weight:700;
  box-shadow:0 4px 20px rgba(22,163,74,.1);
}
.pulse-dot{
  width:10px;height:10px;border-radius:50%;background:#22c55e;
  animation:pulse 1.5s ease-in-out infinite;
}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1);}50%{opacity:.5;transform:scale(1.3);}}

/* ── FOOTER ── */
footer{
  padding:40px 48px;text-align:center;border-top:1px solid rgba(79,70,229,.1);
  position:relative;z-index:10;
}
.footer-name{
  font-size:24px;font-weight:800;letter-spacing:-0.04em;
  background:var(--grad);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.footer-copy{font-size:12px;color:var(--ink2);margin-top:8px;}

/* ── REVEAL ANIMATIONS ── */
.reveal{
  opacity:0;transform:translateY(40px);filter:blur(6px);
  transition:opacity .8s ease,transform .8s ease,filter .8s ease;
}
.reveal.in-view{opacity:1;transform:none;filter:none;}

/* ── RESPONSIVE ── */
@media(max-width:900px){
  body{cursor:auto;}
  #cur-dot,#cur-ring{display:none;}
  .hero-inner{grid-template-columns:1fr;text-align:center;}
  .hero-inner .photo-col{display:none;}
  .hero-stats{justify-content:center;}
  .hero-ctas{justify-content:center;}
  .hero-eyebrow{justify-content:center;}
  .about-grid{grid-template-columns:1fr;}
  .stat-band{grid-template-columns:1fr 1fr;}
  .skills-grid{grid-template-columns:1fr;}
  .contact-cards{grid-template-columns:1fr;}
  .edu-row{grid-template-columns:1fr;gap:8px;}
  section{padding:80px 24px;}
  nav{padding:0 24px;}
  .nav-links{display:none;}
  .exp-big-num{display:none;}
}

/* ── BRANDS ── */
.brands-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:24px;
  margin-bottom:40px;
}
.brand-card{
  background:#fff;
  border:1px solid var(--card-border);
  border-radius:var(--radius);
  padding:32px 24px 24px;
  position:relative;
  overflow:hidden;
  box-shadow:0 8px 40px var(--shadow);
  transition:transform .35s cubic-bezier(.34,1.56,.64,1), box-shadow .35s, border-color .35s;
  cursor:default;
  display:flex;
  flex-direction:column;
  align-items:center;
  text-align:center;
  gap:20px;
}
.brand-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:5px;
  background:var(--grad);
  transform:scaleX(0);transform-origin:left;
  transition:transform .4s ease;
}
.brand-card:hover::before{transform:scaleX(1);}
.brand-card:hover{
  transform:translateY(-8px);
  box-shadow:0 20px 60px rgba(37,99,235,.18);
  border-color:rgba(37,99,235,.3);
}
.brand-card-shine{
  position:absolute;inset:0;
  background:linear-gradient(120deg,transparent 30%,rgba(255,255,255,.35) 50%,transparent 70%);
  transform:translateX(-100%);
  transition:transform .55s ease;
  pointer-events:none;
}
.brand-card:hover .brand-card-shine{transform:translateX(100%);}
.brand-logo-wrap{
  width:120px;height:120px;
  display:flex;align-items:center;justify-content:center;
  background:#ffffff;
  border-radius:16px;
  border:1px solid rgba(79,70,229,.08);
  padding:12px;
  flex-shrink:0;
  transition:transform .35s;
  box-shadow:0 2px 12px rgba(30,41,99,.06);
}
.brand-card:hover .brand-logo-wrap{transform:scale(1.07);}
.brand-logo{
  width:100%;height:100%;
  object-fit:contain;
  mix-blend-mode:multiply;
  filter:contrast(1.05);
}
.brand-info{display:flex;flex-direction:column;gap:6px;}
.brand-name{
  font-size:16px;font-weight:800;letter-spacing:-0.02em;color:var(--ink);
}
.brand-sector{
  font-size:12px;font-weight:400;color:var(--ink2);letter-spacing:.04em;
}
.brands-footer{
  display:flex;justify-content:center;
  margin-top:8px;
}
.brands-count-wrap{
  display:inline-flex;align-items:center;gap:10px;
  padding:12px 28px;border-radius:100px;
  background:#fff;border:1px solid var(--card-border);
  font-size:14px;color:var(--ink2);
  box-shadow:0 4px 20px var(--shadow);
}
.brands-count-wrap strong{
  background:var(--grad);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.brands-dot{
  width:10px;height:10px;border-radius:50%;
  background:var(--grad-diag);flex-shrink:0;
}
@media(max-width:900px){
  .brands-grid{grid-template-columns:repeat(2,1fr);}
}
@media(max-width:500px){
  .brands-grid{grid-template-columns:1fr;}
}


/* ── TOOLS GRID ── */
.tools-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:20px;
  margin-top:0;
}
.tool-card{
  background:#fff;
  border:1px solid var(--card-border);
  border-radius:var(--radius);
  padding:32px 20px 24px;
  display:flex;flex-direction:column;
  align-items:center;text-align:center;
  gap:16px;
  position:relative;overflow:hidden;
  box-shadow:0 4px 24px var(--shadow);
  transition:transform .35s cubic-bezier(.34,1.56,.64,1), box-shadow .35s, border-color .3s;
  cursor:default;
}
.tool-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:4px;
  background:var(--tc-grad,var(--grad));
  transform:scaleX(0);transform-origin:left;
  transition:transform .35s ease;
}
.tool-card:hover::before{transform:scaleX(1);}
.tool-card:hover{
  transform:translateY(-7px);
  box-shadow:0 18px 48px rgba(37,99,235,.15);
  border-color:rgba(37,99,235,.25);
}
.tool-card-shine{
  position:absolute;inset:0;
  background:linear-gradient(120deg,transparent 30%,rgba(255,255,255,.4) 50%,transparent 70%);
  transform:translateX(-100%);transition:transform .5s ease;pointer-events:none;
}
.tool-card:hover .tool-card-shine{transform:translateX(100%);}
.tool-icon-wrap{
  width:72px;height:72px;border-radius:18px;
  display:flex;align-items:center;justify-content:center;
  font-size:38px;line-height:1;
  flex-shrink:0;
  transition:transform .3s;
  position:relative;
}
.tool-card:hover .tool-icon-wrap{transform:scale(1.1) rotate(-3deg);}
.tool-name{font-size:14px;font-weight:800;letter-spacing:-0.02em;color:var(--ink);line-height:1.2;}
.tool-sub{font-size:11px;font-weight:400;color:var(--ink2);letter-spacing:.04em;}
@media(max-width:900px){.tools-grid{grid-template-columns:repeat(2,1fr);}}
@media(max-width:480px){.tools-grid{grid-template-columns:repeat(2,1fr);gap:12px;}}

</style>
</head>
<body>

<!-- SCROLL BAR -->
<div id="scroll-bar"></div>

<!-- CURSOR -->
<div id="cur-dot"></div>
<div id="cur-ring"></div>

<!-- PRELOADER -->
<div id="preloader">
  <span class="pre-pct" id="pre-pct">0%</span>
  <div class="pre-bar-wrap"><div class="pre-bar" id="pre-bar"></div></div>
  <span class="pre-label">Loading Portfolio</span>
</div>
<div class="curtain" id="curtain-top"></div>
<div class="curtain" id="curtain-bot"></div>

<!-- 3D CANVAS -->
<canvas id="bg-canvas"></canvas>

<!-- NAVBAR -->
<nav id="navbar">
  <div class="nav-logo">MP</div>
  <div class="nav-links">
    <a href="#about">About</a>
    <a href="#experience">Work</a>
    <a href="#skills">Skills</a>
    <a href="#contact">Contact</a>
  </div>
</nav>

<main>
<!-- ── HERO ── -->
<section id="hero">
  <div class="hero-watermark" id="watermark">GROWTH</div>
  <div class="hero-inner">
    <div class="hero-content">
      <div class="hero-eyebrow">Performance Marketer · Delhi</div>
      <h1 class="hero-name">
        <span class="hero-name-first" id="name-first"></span>
        <span class="hero-name-last" id="name-last"></span>
      </h1>
      <p class="hero-value">I drive high-intent lead generation through Google Ads and Meta Ads, managing <strong>₹55L+</strong> monthly ad spend while generating <strong>120+ qualified leads per day</strong> with up to <strong>19%</strong> lead-to-enrollment conversion rates.</p>
      <div class="hero-ctas">
        <a href="#contact" class="btn btn-primary magnetic" id="cta-primary">Let's Work Together</a>
        <a href="#experience" class="btn btn-secondary">View My Work</a>
      </div>
      <div class="hero-stats">
        <div class="stat-item"><span class="stat-val">1+</span><span class="stat-lbl">Years Experience</span></div>
        <div class="stat-item"><span class="stat-val">₹55L+</span><span class="stat-lbl">Monthly Ad Spend</span></div>
        <div class="stat-item"><span class="stat-val">120+</span><span class="stat-lbl">Leads Daily</span></div>
        <div class="stat-item"><span class="stat-val">19%</span><span class="stat-lbl">Lead-to-Enrollment</span></div>
      </div>
    </div>
    <div class="photo-col">
      <div class="photo-wrap" id="photo-wrap">
        <div class="photo-glow"></div>
        <div class="photo-ring"></div>
        <div class="photo-frame" id="photo-tilt">
          <img src="data:image/jpeg;base64," alt="Mayank Pal" style="width:100%;height:100%;object-fit:cover;object-position:center top;" />
        </div>
        <div class="orbit-dot" id="od1"></div>
        <div class="orbit-dot" id="od2"></div>
        <div class="orbit-dot" id="od3"></div>
        <div class="chip chip-1"><span class="chip-icon">📈</span><span class="chip-val">2.5X</span><span>Lead Growth</span></div>
        <div class="chip chip-2"><span class="chip-icon">💰</span><span class="chip-val">₹55L+</span><span>Monthly Spend</span></div>
        <div class="chip chip-3"><span class="chip-icon">🎯</span><span class="chip-val">130/day</span><span>Leads</span></div>
      </div>
    </div>
  </div>
</section>

<!-- MARQUEE 1 -->
<div class="marquee-wrap">
  <div class="marquee-inner" id="mq1">
  </div>
</div>
<div class="marquee-wrap alt">
  <div class="marquee-inner" id="mq2">
  </div>
</div>

<!-- ── ABOUT ── -->
<section id="about">
  <div class="container">
    <div class="sec-head reveal">
      <div class="sec-eyebrow"><span class="sec-num">01</span>About Me</div>
      <h2 class="sec-title">Data-driven <span class="sec-grad">marketer</span> with a performance-first mindset</h2>
    </div>
    <div class="about-grid">
      <div class="quote-card reveal">
        <p class="quote-text">"Performance marketing is not about spending more, it's about spending smarter. I combine data, audience insights, and continuous testing to create campaigns that generate qualified leads, improve conversion rates, and deliver measurable business growth."</p>
      </div>
      <div class="stat-band">
        <div class="stat-band-item reveal" style="transition-delay:.1s">
          <span class="stat-band-num counter" data-count="55" data-suffix="L+">₹55L+</span>
          <div class="stat-band-lbl">Monthly Ad Spend</div>
        </div>
        <div class="stat-band-item reveal" style="transition-delay:.2s">
          <span class="stat-band-num counter" data-count="130" data-suffix="/day">130/day</span>
          <div class="stat-band-lbl">Leads Generated</div>
        </div>
        <div class="stat-band-item reveal" style="transition-delay:.3s">
          <span class="stat-band-num counter" data-count="20" data-suffix="%">20%</span>
          <div class="stat-band-lbl">CPL Reduction</div>
        </div>
        <div class="stat-band-item reveal" style="transition-delay:.4s">
          <span class="stat-band-num counter" data-count="6" data-suffix="">6</span>
          <div class="stat-band-lbl">Clients Managed</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- MARQUEE 3 -->
<div class="marquee-wrap" style="margin-bottom:0">
  <div class="marquee-inner" id="mq3"></div>
</div>

<!-- ── EXPERIENCE ── -->
<section id="experience">
  <div class="container">
    <div class="sec-head reveal">
      <div class="sec-eyebrow"><span class="sec-num">02</span>Experience</div>
      <h2 class="sec-title">Where I've <span class="sec-grad">driven</span> results</h2>
    </div>
    <div class="exp-stack" id="exp-stack">

      <!-- EXP 1 -->
      <div class="exp-card reveal" id="ec1">
        <span class="exp-big-num">01</span>
        <div class="exp-date">Jan 2026 – Present · Delhi</div>
        <div class="exp-role">Performance Marketing Executive</div>
        <div class="exp-company">Stealth Digital</div>
        <ul class="exp-bullets">
          <li>Managed <strong>₹55L+</strong> monthly ad spend across 6 education and ed-tech clients.</li>
          <li>Generated <strong>120–130 high-intent leads daily</strong> at CPLs ranging from ₹550–₹750.</li>
          <li>Maintained <strong>9–20% lead-to-enrollment conversion rates</strong> through CRM-driven funnel optimization.</li>
          <li>Reduced average CPL by <strong>15–20%</strong> and cut wasted ad spend by <strong>18%</strong> through bidding improvements.</li>
          <li>Built retargeting campaigns generating <strong>20–30 additional leads</strong> per day per client.</li>
          <li>Improved a school campaign from ₹15L/month spend to <strong>70–80 leads/day</strong> through audience and creative optimization.</li>
        </ul>
        <div class="exp-tags">
          <span class="exp-tag">Google Ads</span>
          <span class="exp-tag">Meta Ads</span>
          <span class="exp-tag">Lead Generation</span>
          <span class="exp-tag">Performance Marketing</span>
        </div>
      </div>

      <!-- EXP 2 -->
      <div class="exp-card reveal" style="transition-delay:.1s" id="ec2">
        <span class="exp-big-num">02</span>
        <div class="exp-date">Jul 2025 – Sep 2025 · Remote</div>
        <div class="exp-role">Social Media Marketing Intern</div>
        <div class="exp-company">MJ Marketing Consultancy</div>
        <ul class="exp-bullets">
          <li>Created branded content and campaign creatives for multiple client accounts.</li>
          <li>Managed content calendars across <strong>Instagram and Facebook</strong>.</li>
          <li>Improved audience engagement through structured content planning.</li>
          <li>Supported social media campaign execution and brand positioning.</li>
          <li>Coordinated with clients to maintain consistent communication and branding.</li>
        </ul>
        <div class="exp-tags">
          <span class="exp-tag">Social Media Marketing</span>
          <span class="exp-tag">Content Strategy</span>
          <span class="exp-tag">Meta Platforms</span>
          <span class="exp-tag">Brand Management</span>
        </div>
      </div>

      <!-- EXP 3 -->
      <div class="exp-card reveal" style="transition-delay:.2s" id="ec3">
        <span class="exp-big-num">03</span>
        <div class="exp-date">May 2025 – Oct 2025 · Delhi</div>
        <div class="exp-role">Digital Marketing Intern</div>
        <div class="exp-company">Webcart Web Services</div>
        <ul class="exp-bullets">
          <li>Managed <strong>Google Ads campaigns</strong> across multiple client accounts.</li>
          <li>Improved Quality Scores through keyword and ad copy optimization.</li>
          <li>Reduced CPCs using audience targeting and campaign refinement.</li>
          <li>Executed technical SEO improvements including <strong>Core Web Vitals optimization</strong>.</li>
          <li>Enhanced organic visibility through keyword research and on-page SEO.</li>
        </ul>
        <div class="exp-tags">
          <span class="exp-tag">Google Ads</span>
          <span class="exp-tag">SEO</span>
          <span class="exp-tag">Technical SEO</span>
          <span class="exp-tag">Digital Marketing</span>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ── SKILLS ── -->
<section id="skills">
  <div class="container">
    <div class="sec-head reveal">
      <div class="sec-eyebrow"><span class="sec-num">03</span>Skills</div>
      <h2 class="sec-title">My <span class="sec-grad">expertise</span> areas</h2>
    </div>
    <div class="skills-grid">
      <div class="skill-card reveal" style="transition-delay:.05s">
        <div class="skill-card-glow"></div>
        <div class="skill-num">01</div>
        <div class="skill-title">Paid Media</div>
        <div class="skill-tags">
          <span class="skill-tag">Google Ads</span>
          <span class="skill-tag">Meta Ads</span>
          <span class="skill-tag">Performance Marketing</span>
          <span class="skill-tag">Lead Generation</span>
          <span class="skill-tag">Campaign Optimization</span>
        </div>
      </div>
      <div class="skill-card reveal" style="transition-delay:.1s">
        <div class="skill-card-glow"></div>
        <div class="skill-num">02</div>
        <div class="skill-title">Analytics & Tracking</div>
        <div class="skill-tags">
          <span class="skill-tag">Google Analytics 4</span>
          <span class="skill-tag">Google Tag Manager</span>
          <span class="skill-tag">Meta Pixel</span>
          <span class="skill-tag">Conversion Tracking</span>
          <span class="skill-tag">Funnel Analysis</span>
        </div>
      </div>
      <div class="skill-card reveal" style="transition-delay:.15s">
        <div class="skill-card-glow"></div>
        <div class="skill-num">03</div>
        <div class="skill-title">Optimization & Strategy</div>
        <div class="skill-tags">
          <span class="skill-tag">A/B Testing</span>
          <span class="skill-tag">Audience Segmentation</span>
          <span class="skill-tag">Bid Strategy</span>
          <span class="skill-tag">Landing Page CRO</span>
          <span class="skill-tag">CRO</span>
        </div>
      </div>
      <div class="skill-card reveal" style="transition-delay:.2s">
        <div class="skill-card-glow"></div>
        <div class="skill-num">04</div>
        <div class="skill-title">SEO & Organic Growth</div>
        <div class="skill-tags">
          <span class="skill-tag">Technical SEO</span>
          <span class="skill-tag">On-Page SEO</span>
          <span class="skill-tag">Keyword Research</span>
          <span class="skill-tag">Core Web Vitals</span>
          <span class="skill-tag">Search Visibility</span>
        </div>
      </div>
    </div>

        <!-- Tools Grid -->
    <div style="margin-top:16px">
      <p class="reveal" style="font-size:15px;color:var(--ink2);margin-bottom:40px;max-width:560px;">Industry-standard platforms I use daily to plan, execute, track, and optimise performance marketing campaigns.</p>
      <div class="tools-grid">
        
      <div class="tool-card reveal" style="transition-delay:0.0s;--tc-grad:linear-gradient(135deg,#4285f4,#34a853)">
        <div class="tool-icon-wrap" style="background:#e8f4fd">
          <svg width="42" height="42" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
