<!-- THREE.JS -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script>
(function(){
'use strict';

/* ── PRELOADER ── */
const pct = document.getElementById('pre-pct');
const bar = document.getElementById('pre-bar');
const preloader = document.getElementById('preloader');
const ctop = document.getElementById('curtain-top');
const cbot = document.getElementById('curtain-bot');
let progress = 0;
const interval = setInterval(()=>{
  progress += Math.random()*8+2;
  if(progress>=100){progress=100;clearInterval(interval);finish();}
  pct.textContent = Math.round(progress)+'%';
  bar.style.width = progress+'%';
},80);

function finish(){
  setTimeout(()=>{
    preloader.style.opacity='0';
    preloader.style.transition='opacity .4s';
    setTimeout(()=>{
      preloader.style.display='none';
      ctop.classList.add('open');
      cbot.classList.add('open');
      setTimeout(()=>{
        ctop.style.display='none';
        cbot.style.display='none';
        revealName();
        document.getElementById('navbar').classList.add('visible');
      },900);
    },400);
  },200);
}

/* ── NAME REVEAL ── */
function revealName(){
  const first='Mayank', last='Pal';
  const f=document.getElementById('name-first');
  const l=document.getElementById('name-last');
  f.innerHTML=''; l.innerHTML='';
  const allChars=[...first,' ',...last];
  let idx=0;
  allChars.forEach((ch,i)=>{
    const span=document.createElement('span');
    span.textContent=ch==' '?'\u00a0':ch;
    span.style.cssText=`
      display:inline-block;
      opacity:0;
      transform:translateY(60px) rotate(8deg);
      transition:opacity .5s ease, transform .5s ease;
      transition-delay:${i*0.06}s;
    `;
    if(i<first.length) f.appendChild(span);
    else if(i>first.length) l.appendChild(span);
  });
  requestAnimationFrame(()=>requestAnimationFrame(()=>{
    document.querySelectorAll('#name-first span,#name-last span').forEach(s=>{
      s.style.opacity='1';
      s.style.transform='none';
    });
  }));
}

/* ── CURSOR ── */
const dot=document.getElementById('cur-dot');
const ring=document.getElementById('cur-ring');
if(dot&&ring){
  let mx=0,my=0,rx=0,ry=0;
  document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;dot.style.left=mx+'px';dot.style.top=my+'px';});
  function animRing(){
    rx+=(mx-rx)*.12; ry+=(my-ry)*.12;
    ring.style.left=rx+'px'; ring.style.top=ry+'px';
    requestAnimationFrame(animRing);
  }
  animRing();
  document.querySelectorAll('a,button,.btn,.skill-card,.exp-card,.contact-card').forEach(el=>{
    el.addEventListener('mouseenter',()=>ring.classList.add('expand'));
    el.addEventListener('mouseleave',()=>ring.classList.remove('expand'));
  });
}

/* ── SCROLL PROGRESS ── */
const scrollBar=document.getElementById('scroll-bar');
window.addEventListener('scroll',()=>{
  const scrolled=(document.documentElement.scrollTop/(document.documentElement.scrollHeight-window.innerHeight))*100;
  scrollBar.style.width=scrolled+'%';
},{ passive:true });

/* ── NAVBAR ── */
const nav=document.getElementById('navbar');
window.addEventListener('scroll',()=>{
  nav.classList.toggle('scrolled',window.scrollY>80);
},{ passive:true });

/* ── WATERMARK PARALLAX ── */
const wm=document.getElementById('watermark');
window.addEventListener('scroll',()=>{
  wm.style.transform=`translateX(calc(-50% + ${window.scrollY*.15}px)) translateY(-50%)`;
},{ passive:true });

/* ── MAGNETIC BUTTON ── */
document.querySelectorAll('.magnetic').forEach(btn=>{
  btn.addEventListener('mousemove',e=>{
    const r=btn.getBoundingClientRect();
    const dx=(e.clientX-r.left-r.width/2)*0.25;
    const dy=(e.clientY-r.top-r.height/2)*0.25;
    btn.style.transform=`translate(${dx}px,${dy}px)`;
  });
  btn.addEventListener('mouseleave',()=>{btn.style.transform='';});
});

/* ── PHOTO TILT ── */
const tilt=document.getElementById('photo-tilt');
if(tilt){
  const pw=document.getElementById('photo-wrap');
  pw.addEventListener('mousemove',e=>{
    const r=pw.getBoundingClientRect();
    const x=(e.clientX-r.left)/r.width-0.5;
    const y=(e.clientY-r.top)/r.height-0.5;
    tilt.style.transform=`rotateY(${x*18}deg) rotateX(${-y*18}deg)`;
  });
  pw.addEventListener('mouseleave',()=>{tilt.style.transform='';});
}

/* ── ORBIT DOTS ── */
(function(){
  const dots=[
    {el:document.getElementById('od1'),r:170,speed:.8,phase:0},
    {el:document.getElementById('od2'),r:165,speed:.5,phase:2.1},
    {el:document.getElementById('od3'),r:172,speed:.7,phase:4.2},
  ];
  function animDots(){
    const t=Date.now()/1000;
    dots.forEach(d=>{
      if(!d.el) return;
      const a=t*d.speed+d.phase;
      d.el.style.left=(Math.cos(a)*d.r+d.r+12)+'px';
      d.el.style.top=(Math.sin(a)*d.r+d.r+12)+'px';
    });
    requestAnimationFrame(animDots);
  }
  animDots();
})();

/* ── SKILL CARD GLOW ── */
document.querySelectorAll('.skill-card').forEach(card=>{
  card.addEventListener('mousemove',e=>{
    const r=card.getBoundingClientRect();
    const x=((e.clientX-r.left)/r.width*100).toFixed(1);
    const y=((e.clientY-r.top)/r.height*100).toFixed(1);
    card.style.setProperty('--mx',x+'%');
    card.style.setProperty('--my',y+'%');
  });
});

/* ── MARQUEE CONTENT ── */
const keywords=['Performance Marketing','Lead Generation','Google Ads','Meta Ads','CRO','Funnel Optimization','A/B Testing','Audience Segmentation','Data-Driven Strategy','Conversion Tracking','GA4','GTM'];
const keywords2=['Growth Hacker','Performance Marketer','Delhi','MBA Marketing','BTech IT','Digital Strategist','Paid Media Expert','ROI Optimizer','Ed-Tech Growth','CPL Reduction'];
const tools=['Google Ads','Meta Ads Manager','GA4','GTM','Meta Pixel','Google Ads Editor','Search Console','Keyword Planner','Canva','WordPress','Excel','CRM Platforms'];

function buildMarquee(id,arr,double){
  const el=document.getElementById(id);
  if(!el) return;
  const items=[...arr,...arr].map(k=>`<span class="mq-item">${k}</span>`).join('');
  el.innerHTML=items+(double?items:'');
}
buildMarquee('mq1',keywords,true);
buildMarquee('mq2',keywords2.map((k,i)=>i%3===1?`<span style="-webkit-text-stroke:1px rgba(255,255,255,.5);color:transparent">${k}</span>`:k),true);
buildMarquee('mq3',keywords,true);

// Tools
(function(){
  const ti=document.getElementById('tools-inner');
  if(!ti) return;
  const arr=[...tools,...tools];
  ti.innerHTML=arr.map(t=>`<span class="tool-pill">${t}</span>`).join('');
})();

/* ── INTERSECTION OBSERVER (reveal) ── */
const revealEls=document.querySelectorAll('.reveal');
const io=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){e.target.classList.add('in-view');io.unobserve(e.target);}
  });
},{threshold:.12,rootMargin:'0px 0px -40px 0px'});
revealEls.forEach(el=>io.observe(el));

/* ── COUNTERS ── */
const counterEls=document.querySelectorAll('.counter');
const cio=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(!e.isIntersecting) return;
    const el=e.target;
    const target=parseFloat(el.dataset.count);
    const suffix=el.dataset.suffix||'';
    const isFloat=!Number.isInteger(target);
    const prefix=el.dataset.prefix||'';
    let start=0, dur=1800;
    const startT=performance.now();
    function step(now){
      const p=Math.min((now-startT)/dur,1);
      const ease=1-Math.pow(1-p,3);
      const val=isFloat?(ease*target).toFixed(1):(Math.round(ease*target));
      el.textContent=prefix+val+suffix;
      if(p<1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
    cio.unobserve(el);
  });
},{threshold:.5});
counterEls.forEach(el=>cio.observe(el));

/* ── STACKING EXPERIENCE CARDS ── */
(function(){
  const cards=document.querySelectorAll('#exp-stack .exp-card');
  if(!cards.length) return;
  cards.forEach((card,i)=>{
    card.style.position='sticky';
    card.style.top=(80+i*16)+'px';
    card.style.zIndex=i+1;
    card.style.marginBottom='24px';
  });
  const sio=new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      if(!e.isIntersecting){
        e.target.style.transform='scale(0.97)';
        e.target.style.opacity='.8';
      } else {
        e.target.style.transform='';
        e.target.style.opacity='1';
      }
    });
  },{threshold:.8});
  cards.forEach(c=>sio.observe(c));
})();

/* ── THREE.JS BACKGROUND ── */
(function(){
  if(typeof THREE==='undefined') return;
  const canvas=document.getElementById('bg-canvas');
  const renderer=new THREE.WebGLRenderer({canvas,antialias:true,alpha:true});
  renderer.setPixelRatio(Math.min(window.devicePixelRatio,2));
  renderer.setSize(window.innerWidth,window.innerHeight);
  renderer.outputEncoding=THREE.sRGBEncoding;
  renderer.toneMapping=THREE.ACESFilmicToneMapping;

  const scene=new THREE.Scene();
  const camera=new THREE.PerspectiveCamera(60,window.innerWidth/window.innerHeight,.1,100);
  camera.position.set(0,0,14);

  // Lights
  scene.add(new THREE.AmbientLight(0xffffff,.4));
  const key=new THREE.DirectionalLight(0xfff8e1,1.2);
  key.position.set(5,8,6);
  scene.add(key);
  const bl=new THREE.PointLight(0x2563eb,2,30);
  bl.position.set(-8,4,4);
  scene.add(bl);
  const vl=new THREE.PointLight(0x7c3aed,1.8,30);
  vl.position.set(8,-4,2);
  scene.add(vl);
  const pl=new THREE.PointLight(0xc026d3,1.5,20);
  pl.position.set(0,8,-4);
  scene.add(pl);

  const pastel=[
    new THREE.Color(.75,.85,1),
    new THREE.Color(.82,.73,.97),
    new THREE.Color(.6,.83,.97),
    new THREE.Color(.97,.73,.87),
    new THREE.Color(.72,.8,.98),
  ];

  function mat(i){
    return new THREE.MeshStandardMaterial({
      color:pastel[i%pastel.length],
      roughness:.18,metalness:.08,
    });
  }

  const shapes=[];
  const geoms=[
    {g:new THREE.TorusGeometry(2.2,.6,24,80),s:1.1,x:-6,y:2.5,z:-4},
    {g:new THREE.IcosahedronGeometry(1.4,1),s:.9,x:6,y:-1,z:-6},
    {g:new THREE.TorusKnotGeometry(1,.35,120,18),s:.8,x:5,y:3.5,z:-8},
    {g:new THREE.SphereGeometry(1.6,40,40),s:1,x:-5,y:-3,z:-5},
    {g:new THREE.SphereGeometry(.8,32,32),s:.7,x:2,y:5,z:-7},
    {g:new THREE.OctahedronGeometry(1.2,0),s:.85,x:-3,y:1,z:-9},
    {g:new THREE.SphereGeometry(1,32,32),s:.75,x:3,y:-4.5,z:-6},
    {g:new THREE.TorusGeometry(1.2,.4,20,60),s:.7,x:0,y:-6,z:-8},
  ];
  geoms.forEach((d,i)=>{
    const mesh=new THREE.Mesh(d.g,mat(i));
    mesh.position.set(d.x,d.y,d.z);
    mesh.scale.setScalar(d.s);
    mesh.userData={
      phase:Math.random()*Math.PI*2,
      speed:(.15+Math.random()*.15),
      floatAmp:.6+Math.random()*.6,
      rotX:Math.random()*.4,
      rotY:Math.random()*.4,
    };
    scene.add(mesh);
    shapes.push(mesh);
  });

  // Dust
  const pCount=260;
  const pGeo=new THREE.BufferGeometry();
  const pPos=new Float32Array(pCount*3);
  for(let i=0;i<pCount;i++){
    pPos[i*3]=(Math.random()-0.5)*40;
    pPos[i*3+1]=(Math.random()-0.5)*30;
    pPos[i*3+2]=(Math.random()-.5)*20-5;
  }
  pGeo.setAttribute('position',new THREE.BufferAttribute(pPos,3));
  const pMat=new THREE.PointsMaterial({color:0x7c3aed,size:.05,transparent:true,opacity:.35});
  scene.add(new THREE.Points(pGeo,pMat));

  // Mouse + scroll
  let tgX=0,tgY=0,curX=0,curY=0,scrollY=0;
  document.addEventListener('mousemove',e=>{
    tgX=(e.clientX/window.innerWidth-.5)*3;
    tgY=-(e.clientY/window.innerHeight-.5)*2;
  });
  window.addEventListener('scroll',()=>{scrollY=window.scrollY;},{passive:true});

  window.addEventListener('resize',()=>{
    camera.aspect=window.innerWidth/window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth,window.innerHeight);
  });

  let t=0;
  function animate(){
    requestAnimationFrame(animate);
    t+=.006;
    curX+=(tgX-curX)*.04;
    curY+=(tgY-curY)*.04;
    camera.position.x=curX;
    camera.position.y=curY-(scrollY*.002);
    shapes.forEach(s=>{
      const u=s.userData;
      s.rotation.x+=u.rotX*.01;
      s.rotation.y+=u.rotY*.012;
      s.position.y+=Math.sin(t*u.speed+u.phase)*u.floatAmp*.008;
    });
    renderer.render(scene,camera);
  }
  animate();
})();

})();
</script>
</body>
</html>
