      </div>
      <div class="tool-card reveal" style="transition-delay:0.14s;--tc-grad:linear-gradient(135deg,#E37400,#F29900)">
        <div class="tool-icon-wrap" style="background:#fff4e0">
          <svg width="42" height="42" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
