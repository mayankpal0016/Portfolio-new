          <div class="tool-name">Google Ads</div>
          <div class="tool-sub">Search · Display</div>
        </div>
        <div class="tool-card-shine"></div>
      </div>
      <div class="tool-card reveal" style="transition-delay:0.07s;--tc-grad:linear-gradient(135deg,#0866ff,#0080ff)">
        <div class="tool-icon-wrap" style="background:#e7f0ff">
          <svg width="42" height="42" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
