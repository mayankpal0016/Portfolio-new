</svg>
        </div>
        <div>
          <div class="tool-name">Google Analytics 4</div>
          <div class="tool-sub">GA4 · Reporting</div>
        </div>
        <div class="tool-card-shine"></div>
      </div>
      <div class="tool-card reveal" style="transition-delay:0.21000000000000002s;--tc-grad:linear-gradient(135deg,#4285F4,#34A853)">
        <div class="tool-icon-wrap" style="background:#eef4ff">
          <svg width="42" height="42" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
  <rect x="6" y="6" width="36" height="36" rx="8" fill="#4285F4"/>
  <path d="M24 14 L14 24 L24 34 L34 24 Z" fill="#fff" opacity="0.9"/>
  <path d="M24 18 L18 24 L24 30 L30 24 Z" fill="#4285F4"/>
</svg>
        </div>
        <div>
          <div class="tool-name">Google Tag Manager</div>
          <div class="tool-sub">GTM · Event Tracking</div>
        </div>
        <div class="tool-card-shine"></div>
      </div>
      <div class="tool-card reveal" style="transition-delay:0.0s;--tc-grad:linear-gradient(135deg,#0866ff,#23a6d5)">
        <div class="tool-icon-wrap" style="background:#e7f0ff">
          <svg width="42" height="42" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
  <circle cx="24" cy="24" r="20" fill="#0866FF" opacity="0.12"/>
